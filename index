<!DOCTYPE html>
<html lang="ko">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <link href="https://fonts.googleapis.com/css2?family=EB+Garamond:ital,wght@0,400..800;1,400..800&family=PT+Serif:ital,wght@0,400;0,700;1,400;1,700&family=Unna:ital,wght@0,400;0,700;1,400;1,700&display=swap" rel="stylesheet">
<title>Ever Thine, Ever Mine, Ever Ours</title>
    <style>
        :root {
            --paper: #fdfdfc;
	--gold-foil: linear-gradient(
                135deg, 
                #a67c00 0%,   /* 어두운 금 */
                #bf9b30 25%,  /* 중간 금 */
                #fae04b 50%,  /* 하이라이트 (가장 밝은 반사광) */
                #b38b1a 75%,  /* 다시 어두운 금 */
                #f2d16d 100%  /* 따뜻한 금 */
	)
        }
        
        /* 전체 배경: 스크롤 금지 */
    
    body, html { 
        background-color: #ede9e0;
        margin: 0; padding: 0;
        width: 100%; height: 100%;
        overflow: hidden;
        display: flex; justify-content: center; align-items: center;
        /* 전체적으로 터치 하이라이트를 막고 싶을 때 body에 추가 */
        -webkit-tap-highlight-color: transparent; 
    }

    #container {
        width: 90%; max-width: 350px; height: 500px;
        display: flex; justify-content: center; align-items: center;
        cursor: pointer;
        /* 특정 컨테이너에서 하이라이트 제거 */
        -webkit-tap-highlight-color: transparent;
        outline: none;
        perspective: 1000px;
    }


        .card {
            background-color: var(--paper);
            width: 90%; max-width: 380px;
            height: 95%;
            padding: 40px 20px;
            border-radius: 10px;
            display: flex; flex-direction: column; align-items: center; justify-content: center;
            box-sizing: border-box;
            position: absolute;
            transition: all 0.8s cubic-bezier(0.4, 0, 0.2, 1);
            backface-visibility: hidden;
	box-shadow: 0 10px 30px rgba(0,0,0,0.1); 
	border: 1px solid #d4cbb3;
        }

        /* 앞장 스타일 */
        #front-card { z-index: 2; opacity: 1; }
        
        /* 뒷장 스타일: 처음엔 숨김 */
        #back-card { 
            z-index: 1; opacity: 0; 
            transform: translateY(20px); /* 살짝 아래에 배치했다가 올라오게 */
	text-align: center;
	justify-content: space-between;
	padding: 20px 20px;!important
        }

        /* 전환 효과 클래스 */
        .hidden { opacity: 0 !important; transform: translateY(-20px); pointer-events: none; }
        .visible { opacity: 1 !important; transform: translateY(0) !important; }

        /* 순차 페이드인 문구 */
        .vow-text {
            font-family: 'PT Serif', serif;
            font-size: 1.25rem; line-height: 2;
            color: #444; letter-spacing: 0.15em;
            text-align: center;
	}
        
        .fade-in-line {
            opacity: 0;
            animation: fadeInNext 1.5s ease-out forwards;
        }
        @keyframes fadeInNext {
            from { opacity: 0; transform: translateY(5px); }
            to { opacity: 1; transform: translateY(0); }
        }        
        .top-quote {
            font-family: 'Unna', serif;
            font-size: 0.7rem; line-height: 1.8;
            color: #424242; margin-bottom: 40px;
            word-break: keep-all;
        }

/* 새로 추가된 전체 왼쪽 정렬용 컨테이너 */
.main-names-container {
    width: 100%;
    display: flex;
    justify-content: flex-start; /* 왼쪽 정렬 */
    padding-left: 20px; /* 전체적인 왼쪽 여백 (취향껏 조절) */
    margin-bottom: 10px;
padding-bottom: 5px;
}

        .main-names {
	font-family: "EB Garamond", serif;
  	font-optical-sizing: auto;
  	font-style: normal;
            font-size: 2.2rem; /* 이름 크기를 살짝 더 키워 로고 느낌 강조 */
            margin-bottom: 10px; letter-spacing: 0.03em;
	line-height : 0.9;
            font-weight: 350; /* 굵게 해야 금박이 잘 보임 */ 
padding-bottom: 5px;
/* 추가된 부분: 왼쪽 정렬 및 세로 배치 */
    text-align: left;
    display: flex;
    flex-direction: column;
            background: var(--gold-foil);
            -webkit-background-clip: text; /* 그라데이션을 텍스트 안에만 집어넣음 */
            -webkit-text-fill-color: transparent; /* 기존 글자색을 투명하게 해서 그라데이션이 보이게 함 */
        }

/* 핵심: Honey B를 + 기호 아래로 밀어버리는 마진 */
.honey-b {
    /* Jack Abbot 글자 수만큼 수동으로 밀어주는 설정 */
    /* 폰트마다 다르지만 PT Serif 기준 6.3em 정도면 + 아래에 옵니다 */
    margin-left: 4.2rem; 
}


        .detail-info {
	text-align:right;
            font-family: 'Unna', serif;
            font-size: 0.6rem; line-height: 1;
            padding-top: 10px; width: 100%;
	color:#424242;
        }
        .detail-item { display: block; margin-bottom: 4px; }

        /* 뒷장 세부 디자인 */
        .info-title { font-size: 0.9rem; color: #aaa; letter-spacing: 0.2em; margin-bottom: 10px; }
        .names { font-size: 1.5rem; color: #222; margin: 25px 0; }
        .date-location { font-size: 1rem; line-height: 2; color: #666; }

        /* 터치 가이드 */
        .touch-hint {
            position: absolute; bottom: 30px;
            font-size: 0.75rem; color: #bbb;
            letter-spacing: 0.1em;
	animation: pulse 3s ease-in-out infinite;
	pointer-events: none;
        }

       /* 밝기가 변화하는 애니메이션 정의 */
@keyframes pulse {
    0% {
        opacity: 0.3; /* 어두워졌다가 */
    }
    50% {
        opacity: 1;   /* 다시 밝아짐 */
    }
    100% {
        opacity: 0.3; /* 다시 어두워짐 */
    }
}
    </style>
</head>
<body>
<audio id="bgm" src="beethoven.mp3" preload="auto"></audio>
    <div id="container" onclick="flipCard()">
        <div id="front-card" class="card">
            <div class="vow-text">
                <div class="fade-in-line" style="animation-delay: 0.5s;">ever thine</div>
                <div class="fade-in-line" style="animation-delay: 1.8s;">ever mine</div>
                <div class="fade-in-line" style="animation-delay: 3.1s;">ever ours</div>
            </div>
            <div class="touch-hint">Please join us</div>
        </div>

<div id="back-card" class="card">
            <div class="top-quote">
                We request the honor of your presence to witness our vow <br>to illuminate each other's darkness.
            </div>

<div class="main-names-container">
    <div class="main-names">
        <div class="name-row-1">Jack Abbot +</div>
        <div class="name-row-2">
            <span class="honey-b">Honey B</span>
        </div>
    </div>
</div>

            <div class="detail-info">
                <span class="detail-item">SATURDAY, THE 23RD OF MAY, 2026.</span>
                <span class="detail-item">AT 2PM, CEREMONY</span>
                <span class="detail-item">THE AETHELGARD GLASSHOUSE</span>
                <span class="detail-item">77 BINDLANE PA 15102</span>
                <span class="detail-item">RECEPTION TO FOLLOW</span><br><br>
                <span class="detail-item">KINDLY RSVP</span>
                <span class="detail-item">to jackabbot@ptmc.com</span>
                <span class="detail-item">by 7th May 2026</span>
            </div>
    </div>

  <script>
        let isBack = false;

        function flipCard() {
            const front = document.getElementById('front-card');
            const back = document.getElementById('back-card');
	const bgm = document.getElementById('bgm'); // 오디오 가져오기
            
            if (!isBack) {
                front.classList.add('hidden');
                back.classList.add('visible');
       bgm.play().catch(e => {
            console.log("재생 실패: ", e); // 혹시 모를 에러 대비
        });
                isBack = true;
            } else {
                front.classList.remove('hidden');
                back.classList.remove('visible');
                isBack = false;
            }
        }
    </script>
</body>
</html>
